# Server-only GitHub token. Do not use NEXT_PUBLIC_ for this.
# For local dev you can run:
#   GITHUB_TOKEN="$(gh auth token)" GITHUB_ORG=your-org npm run dev
GITHUB_TOKEN=

# GitHub org slug to live-fetch. When set together with GITHUB_TOKEN, the org
# is added to the leaderboard as a live row with private-repo coverage.
GITHUB_ORG=

# Optional: better Peter Density denominator than org member count.
GITHUB_ORG_ACTIVE_CONTRIBUTORS=

# Optional: override the repo count surfaced in the trust panel.
GITHUB_ORG_REPOSITORIES=

# Optional: friendly display name (defaults to GitHub org's name).
GITHUB_ORG_DISPLAY_NAME=

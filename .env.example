# Server-only GitHub token. Do not use NEXT_PUBLIC_ for this.
# For local dev you can run:
#   GITHUB_TOKEN="$(gh auth token)" npm run dev
GITHUB_TOKEN=

# Optional: override if the real private org slug is different.
INCREDIBUILD_GITHUB_ORG=Incredibuild-RND

# Optional: provide a better density denominator than org member count.
INCREDIBUILD_ACTIVE_CONTRIBUTORS=
INCREDIBUILD_REPOSITORIES=
INCREDIBUILD_DISPLAY_NAME=Incredibuild
